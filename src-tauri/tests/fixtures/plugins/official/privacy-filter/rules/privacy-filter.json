{
  "rules": [
    {
      "id": "privacy-filter-message-email",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}" },
      "action": { "kind": "replace", "replacement": "[EMAIL]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-cn-phone",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "(^|[^0-9])((?:\\+?86[-\\s]?)?1[3-9][0-9]{9})([^0-9]|$)" },
      "action": { "kind": "replace", "replacement": "$1[PHONE]$3" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-cn-id-card",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "[1-9][0-9]{16}[0-9Xx]" },
      "action": { "kind": "replace", "replacement": "[CN_ID_CARD]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-ipv4",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]?[0-9])" },
      "action": { "kind": "replace", "replacement": "[IP]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-bank-card-candidate",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "[0-9][0-9 -]{11,23}[0-9]" },
      "action": { "kind": "replace", "replacement": "[BANK_CARD]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-openai-key",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "sk-(?:proj-)?[A-Za-z0-9_-]{20,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-aws-access-key",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "AKIA[0-9A-Z]{16}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-github-token",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "github_(?:pat|classic)_[A-Za-z0-9_]{10,}|gh[pousr]_[A-Za-z0-9_]{20,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-google-api-key",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "AIza[0-9A-Za-z_-]{35}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-slack-token",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "xox[baprs]-[0-9A-Za-z-]{10,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-jwt",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "eyJ[A-Za-z0-9_-]{8,}\\.eyJ[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-private-key",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "-----BEGIN[A-Z ]*PRIVATE KEY-----" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-bearer-token",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "(?i)\\b(Bearer\\s+)[A-Za-z0-9._~+/=-]{12,}" },
      "action": { "kind": "replace", "replacement": "$1[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-url-query-secret",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "([?&](?:token|api_key|key|access_token)=)[^\\s&]+" },
      "action": { "kind": "replace", "replacement": "$1[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },
    {
      "id": "privacy-filter-message-context-secret",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body", "jsonPath": "$.messages[*].content" },
      "match": { "regex": "(?i)\\b((?:password|passwd|pwd|secret|token|api[_\\s-]?key|access[_\\s-]?key|credential|密钥|密码|口令|凭证|令牌)\\s*(?:是|为|:|：|=)\\s*['\"]?)[^\\s'\"，。；;]{4,}" },
      "action": { "kind": "replace", "replacement": "$1[SECRET]" },
      "when": { "configEquals": { "redactBeforeUpstream": true } }
    },

