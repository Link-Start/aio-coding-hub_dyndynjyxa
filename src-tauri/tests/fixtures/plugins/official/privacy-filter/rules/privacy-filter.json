      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "github_(?:pat|classic)_[A-Za-z0-9_]{10,}|gh[pousr]_[A-Za-z0-9_]{20,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-google-api-key",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "AIza[0-9A-Za-z_-]{35}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-slack-token",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "xox[baprs]-[0-9A-Za-z-]{10,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-jwt",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "eyJ[A-Za-z0-9_-]{8,}\\.eyJ[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-private-key",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "-----BEGIN[A-Z ]*PRIVATE KEY-----" },
      "action": { "kind": "replace", "replacement": "[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-bearer-token",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "(?i)\\b(Bearer\\s+)[A-Za-z0-9._~+/=-]{12,}" },
      "action": { "kind": "replace", "replacement": "$1[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-url-query-secret",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "([?&](?:token|api_key|key|access_token)=)[^\\s&]+" },
      "action": { "kind": "replace", "replacement": "$1[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    },
    {
      "id": "privacy-filter-log-context-secret",
      "hook": "log.beforePersist",
      "target": { "field": "log.message" },
      "match": { "regex": "(?i)\\b((?:password|passwd|pwd|secret|token|api[_\\s-]?key|access[_\\s-]?key|credential|密钥|密码|口令|凭证|令牌)\\s*(?:是|为|:|：|=)\\s*['\"]?)[^\\s'\"，。；;]{4,}" },
      "action": { "kind": "replace", "replacement": "$1[SECRET]" },
      "when": { "configEquals": { "redactLogs": true } }
    }
  ]
}
