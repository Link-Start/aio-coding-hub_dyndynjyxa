{
  "rules": [
    {
      "id": "prompt-optimizer-messages",
      "hook": "gateway.request.afterBodyRead",
      "target": { "field": "request.body" },
      "match": { "regex": "\"messages\"\\s*:" },
      "action": {
        "kind": "appendMessage",
        "role": "system",
        "content": "Clarify the user request, preserve intent, and answer with actionable structure."
      }
    },
    {
      "id": "prompt-optimizer-input",
      "hook": "gateway.request.afterBodyRead",
      "target": {
        "field": "request.body",
        "jsonPath": "$.input"
      },
      "match": { "regex": "(.|\\n)+" },
      "action": {
        "kind": "replace",
        "replacement": "Clarify the user request, preserve intent, and answer with actionable structure.\n\n$0"
      }
    },
    {
      "id": "prompt-optimizer-prompt",
      "hook": "gateway.request.afterBodyRead",
      "target": {
        "field": "request.body",
        "jsonPath": "$.prompt"
      },
      "match": { "regex": "(.|\\n)+" },
      "action": {
        "kind": "replace",
        "replacement": "Clarify the user request, preserve intent, and answer with actionable structure.\n\n$0"
      }
    }
  ]
}
